# =============================================================================
# VibeCode Backend — Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# --- LLM Configuration (YOU provide this) ---
# Your LLM API key. Get one from:
#   DeepSeek:  https://platform.deepseek.com/api_keys
#   Claude:    https://console.anthropic.com/settings/keys
#   OpenAI:    https://platform.openai.com/api-keys
#   Groq:      https://console.groq.com/keys
#   OpenRouter: https://openrouter.ai/keys
LLM_API_KEY=sk-your-key-here

# Model name (defaults shown below):
#   DeepSeek:  deepseek-chat
#   Claude:    claude-sonnet-4-20250514
#   OpenAI:    gpt-4o
#   Groq:      llama-3.3-70b-versatile
LLM_MODEL=deepseek-chat

# Base URL (only needed for non-standard providers):
#   DeepSeek:  https://api.deepseek.com/v1
#   OpenAI:    (leave empty)
#   Claude:    (leave empty — SDK uses Anthropic default)
#   Groq:      https://api.groq.com/openai/v1
#   OpenRouter: https://openrouter.ai/api/v1
LLM_BASE_URL=https://api.deepseek.com/v1

# --- OpenHands Cloud (YOU provide this) ---
# Get your API key: https://app.all-hands.dev → Settings → API Keys
OPENHANDS_CLOUD_API_KEY=your-openhands-key-here

# --- Firebase Cloud Messaging (YOU provide this) ---
# Download from Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_CREDENTIALS_PATH=/opt/vibecode/firebase-credentials.json

# --- Server ---
HOST=0.0.0.0
PORT=8080
