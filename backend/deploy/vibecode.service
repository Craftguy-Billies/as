[Unit]
Description=VibeCode Backend Server
After=network.target

[Service]
Type=simple
User=vibecode
WorkingDirectory=/opt/vibecode
EnvironmentFile=/opt/vibecode/.env
ExecStart=/opt/vibecode/.venv/bin/python -m uvicorn main:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=vibecode

[Install]
WantedBy=multi-user.target
